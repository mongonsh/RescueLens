{
  "mcpServers": {
    "phoenix": {
      "command": "npx",
      "args": [
        "-y",
        "@arizeai/phoenix-mcp@latest",
        "--baseUrl",
        "${PHOENIX_BASE_URL}",
        "--apiKey",
        "${PHOENIX_API_KEY}"
      ],
      "env": {
        "PHOENIX_BASE_URL": "${PHOENIX_BASE_URL}",
        "PHOENIX_API_KEY": "${PHOENIX_API_KEY}"
      }
    }
  }
}
