GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
GEMINI_AGENT_MODEL=gemini-3.5-flash
GEMINI_FALLBACK_MODEL=gemini-2.5-flash
GEMINI_TTS_MODEL=gemini-3.1-flash-tts-preview
GEMINI_TTS_VOICE=Kore

GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_REGION=us-central1
AGENT_BUILDER_LOCATION=global
AGENT_BUILDER_AGENT_ID=
AGENT_BUILDER_ENDPOINT=
AGENT_BUILDER_ENDPOINT_AUTH=bearer
AGENT_BUILDER_ENDPOINT_TOKEN=
AGENT_BUILDER_ENDPOINT_TOKEN_TYPE=id_token
AGENT_BUILDER_ENDPOINT_AUDIENCE=
AGENT_BUILDER_ENDPOINT_API_KEY=
AGENT_BUILDER_BASE_AGENT=antigravity-preview-05-2026
AGENT_BUILDER_API_REVISION=2026-05-20
GOOGLE_CLOUD_ACCESS_TOKEN=
AGENT_BUILDER_USE_METADATA_TOKEN=false
AGENT_BUILDER_TIMEOUT_MS=15000
AGENT_BUILDER_AUTH_TIMEOUT_MS=1800

PHOENIX_BASE_URL=
PHOENIX_API_KEY=
PHOENIX_COLLECTOR_ENDPOINT=
ARIZE_API_KEY=
ARIZE_SPACE_ID=

# Optional MCP bridge modes.
# HTTP JSON-RPC bridge:
ARIZE_MCP_HTTP_URL=

# Stdio MCP server. If empty and PHOENIX_BASE_URL is set,
# RescueLens attempts: npx -y @arizeai/phoenix-mcp@latest --baseUrl ... --apiKey ...
ARIZE_MCP_COMMAND=
ARIZE_MCP_ARGS=
ARIZE_MCP_TIMEOUT_MS=12000

# Public live-data feeds and location search.
NWS_USER_AGENT=RescueLens hackathon demo; contact=dev@example.com
LOCATION_GEOCODER=openmeteo
NOMINATIM_USER_AGENT=RescueLens hackathon demo; contact=dev@example.com
NOMINATIM_REFERER=http://localhost:3000
LIVE_DATA_TIMEOUT_MS=8000
LIVE_DATA_LIMIT=24
LOCATION_SEARCH_EVENT_LIMIT=12
